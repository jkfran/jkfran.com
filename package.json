{
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{html,scss,js,md,yml}\"",
    "format:check": "prettier --check \"**/*.{html,scss,js,md,yml}\"",
    "lint:css": "stylelint \"_sass/**/*.scss\"",
    "lint:css:fix": "stylelint \"_sass/**/*.scss\" --fix",
    "lint:js": "eslint \"assets/js/mediumish.js\"",
    "lint": "npm run lint:css && npm run lint:js && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0"
  }
}
